        "selector": "JSXOpeningElement[name.name='IconButton'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:ghost|solid|soft)$/]",
        "message": "<IconButton> variant must be one of 'ghost' | 'solid' | 'soft'."

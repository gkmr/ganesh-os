{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/content/**",
              "components/core/**",
              "components/data/**",
              "components/diagrams/**",
              "components/feedback/**",
              "components/forms/**",
              "components/messaging/**",
              "components/navigation/**",
              "ui_kits/digest/**",
              "ui_kits/docs/**",
              "ui_kits/landing/**",
              "ui_kits/operator/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Inter|JetBrains Mono))/i]",
        "message": "Font not provided by the design system. Available: Inter, JetBrains Mono."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|tone|pulse|children|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: variant, tone, pulse, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:kicker|tag|square)$/]",
        "message": "<Badge> variant must be one of 'kicker' | 'tag' | 'square'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:brand|violet|pass|fail|neutral)$/]",
        "message": "<Badge> tone must be one of 'brand' | 'violet' | 'pass' | 'fail' | 'neutral'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|as|disabled|children|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, as, disabled, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|ghost|soft)$/]",
        "message": "<Button> variant must be one of 'primary' | 'ghost' | 'soft'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='as'] > Literal[value!=/^(?:button|a)$/]",
        "message": "<Button> as must be one of 'button' | 'a'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute > JSXIdentifier[name!=/^(?:accent|accentSide|interactive|gradientSurface|children|key|ref|className|style|children)$/]",
        "message": "<Card> doesn't accept that prop. Declared props: accent, accentSide, interactive, gradientSurface, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute[name.name='accentSide'] > Literal[value!=/^(?:top|left)$/]",
        "message": "<Card> accentSide must be one of 'top' | 'left'."
      },
      {
        "selector": "JSXOpeningElement[name.name='ChangeLogLine'] > JSXAttribute > JSXIdentifier[name!=/^(?:time|agent|field|verdict|note|blocked|key|ref|className|style|children)$/]",
        "message": "<ChangeLogLine> doesn't accept that prop. Declared props: time, agent, field, verdict, note, blocked."
      },
      {
        "selector": "JSXOpeningElement[name.name='ChannelTag'] > JSXAttribute > JSXIdentifier[name!=/^(?:channel|key|ref|className|style|children)$/]",
        "message": "<ChannelTag> doesn't accept that prop. Declared props: channel."
      },
      {
        "selector": "JSXOpeningElement[name.name='Checkbox'] > JSXAttribute > JSXIdentifier[name!=/^(?:checked|onChange|label|disabled|key|ref|className|style|children)$/]",
        "message": "<Checkbox> doesn't accept that prop. Declared props: checked, onChange, label, disabled."
      },
      {
        "selector": "JSXOpeningElement[name.name='CodeBlock'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|children|key|ref|className|style|children)$/]",
        "message": "<CodeBlock> doesn't accept that prop. Declared props: title, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='DayPlanTop'] > JSXAttribute > JSXIdentifier[name!=/^(?:domain|text|key|ref|className|style|children)$/]",
        "message": "<DayPlanTop> doesn't accept that prop. Declared props: domain, text."
      },
      {
        "selector": "JSXOpeningElement[name.name='DayPlanTop'] > JSXAttribute[name.name='domain'] > Literal[value!=/^(?:work|health|people|growth)$/]",
        "message": "<DayPlanTop> domain must be one of 'work' | 'health' | 'people' | 'growth'."
      },
      {
        "selector": "JSXOpeningElement[name.name='DecisionRow'] > JSXAttribute > JSXIdentifier[name!=/^(?:handle|list|title|due|tag|decision|applied|key|ref|className|style|children)$/]",
        "message": "<DecisionRow> doesn't accept that prop. Declared props: handle, list, title, due, tag, decision, applied."
      },
      {
        "selector": "JSXOpeningElement[name.name='DiagramFrame'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|caption|children|key|ref|className|style|children)$/]",
        "message": "<DiagramFrame> doesn't accept that prop. Declared props: title, caption, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Dialog'] > JSXAttribute > JSXIdentifier[name!=/^(?:open|onClose|title|width|children|style|key|ref|className|style|children)$/]",
        "message": "<Dialog> doesn't accept that prop. Declared props: open, onClose, title, width, children, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='DigestItem'] > JSXAttribute > JSXIdentifier[name!=/^(?:handle|text|decision|key|ref|className|style|children)$/]",
        "message": "<DigestItem> doesn't accept that prop. Declared props: handle, text, decision."
      },
      {
        "selector": "JSXOpeningElement[name.name='DomainLane'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|sub|domain|count|quiet|flow|delay|key|ref|className|style|children)$/]",
        "message": "<DomainLane> doesn't accept that prop. Declared props: name, sub, domain, count, quiet, flow, delay."
      },
      {
        "selector": "JSXOpeningElement[name.name='ScorecardDomain'] > JSXAttribute > JSXIdentifier[name!=/^(?:domain|label|value|ok|key|ref|className|style|children)$/]",
        "message": "<ScorecardDomain> doesn't accept that prop. Declared props: domain, label, value, ok."
      },
      {
        "selector": "JSXOpeningElement[name.name='ScorecardDomain'] > JSXAttribute[name.name='domain'] > Literal[value!=/^(?:work|health|people|growth)$/]",
        "message": "<ScorecardDomain> domain must be one of 'work' | 'health' | 'people' | 'growth'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Handle'] > JSXAttribute > JSXIdentifier[name!=/^(?:id|decision|key|ref|className|style|children)$/]",
        "message": "<Handle> doesn't accept that prop. Declared props: id, decision."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconButton'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|round|label|disabled|children|key|ref|className|style|children)$/]",
        "message": "<IconButton> doesn't accept that prop. Declared props: variant, size, round, label, disabled, children."

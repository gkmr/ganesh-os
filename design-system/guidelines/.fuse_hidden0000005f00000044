<!-- @dsCard group="Spacing" viewport="700x150" name="Spacing scale" subtitle="4 → 84px rhythm; 1140px max, 24px gutters" -->
<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<link rel="stylesheet" href="../styles.css">
<style>
  body{margin:0;background:var(--bg);font-family:var(--font-sans);padding:22px;color:var(--body)}
  .stack{display:flex;flex-direction:column;gap:9px}
  .r{display:flex;align-items:center;gap:12px}
  .bar{height:13px;background:var(--grad-bar);border-radius:3px}
  .lab{font-family:var(--font-mono);font-size:11.5px;color:var(--muted);width:120px}
</style>
</head>
<body>
  <div class="stack">
    <div class="r"><span class="lab">--space-2 · 8</span><span class="bar" style="width:8px"></span></div>
    <div class="r"><span class="lab">--space-4 · 16</span><span class="bar" style="width:16px"></span></div>
    <div class="r"><span class="lab">--space-6 · 24</span><span class="bar" style="width:24px"></span></div>
    <div class="r"><span class="lab">--space-10 · 40</span><span class="bar" style="width:40px"></span></div>
    <div class="r"><span class="lab">--section · 84</span><span class="bar" style="width:84px"></span></div>
  </div>
</body>
</html>

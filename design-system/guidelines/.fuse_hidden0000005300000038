<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<link rel="stylesheet" href="../styles.css">
<style>
  body{margin:0;background:var(--bg);font-family:var(--font-sans);padding:20px;color:var(--body)}
  .row{display:flex;gap:12px;flex-wrap:wrap}
  .sw{flex:1;min-width:110px;border-radius:var(--r-lg);padding:14px;border:1px solid var(--line);color:var(--ink);min-height:92px;display:flex;flex-direction:column;justify-content:flex-end;gap:5px}
  .sw .n{font:var(--text-mono-label);color:var(--muted);text-transform:uppercase;letter-spacing:var(--ls-mono)}
  .sw .h{font-family:var(--font-mono);font-size:11.5px;color:var(--faint)}
</style>
</head>
<body>
  <div class="row">
    <div class="sw" style="background:var(--bg)"><div class="n">--bg</div><div class="h">#070a14</div></div>
    <div class="sw" style="background:var(--bg-2)"><div class="n">--bg-2</div><div class="h">#0a0f1f</div></div>
    <div class="sw" style="background:var(--surface-2)"><div class="n">--surface-2</div><div class="h">#0d1322</div></div>
    <div class="sw" style="background:var(--surface)"><div class="n">--surface</div><div class="h">#111829</div></div>
    <div class="sw" style="background:var(--raise)"><div class="n">--raise</div><div class="h">#161f33</div></div>
  </div>
</body>
</html>
